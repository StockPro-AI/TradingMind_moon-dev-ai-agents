# DATA
ALPHA_VANTAGE_API_KEY=alpha_vantage_api_key_placeholder

# LLM
ANTHROPIC_API_KEY=anthropic_api_key_placeholder
OPENAI_API_KEY=openai_api_key_placeholder
DEEPSEEK_API_KEY=deepseek_api_key_placeholder

# MEMORY (set to false to disable memory/learning features and avoid needing OpenAI API for embeddings)
USE_MEMORY=true

# REDIS CACHE (optional - for caching analysis results)
# If Redis is not available, caching will be automatically disabled
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# LOGGING (set to true to enable verbose debug logging)
DEBUG_LOGGING=false
